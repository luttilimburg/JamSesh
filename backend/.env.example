# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ── Django core ──────────────────────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of domains/IPs that Django will serve
# e.g.  api.muscimeet.com,muscimeet.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (dev only).
# PostgreSQL example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# ── Email (Gmail App Password) ────────────────────────────────────────────────
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id

# ── AWS S3 media storage ──────────────────────────────────────────────────────
# Leave empty to store files locally (dev only).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Leave empty to allow all origins (fine for mobile-only apps).
# Set to a comma-separated list if you add a web frontend.
CORS_ALLOWED_ORIGINS=
